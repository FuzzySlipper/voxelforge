{
  "name": "voxelforge-electron",
  "version": "0.2.0",
  "description": "VoxelForge Electron renderer — Three.js static mesh renderer",
  "main": "dist/main/index.js",
  "scripts": {
    "build": "tsc && esbuild src/renderer/index.ts --bundle --outfile=dist/renderer/bundle.js --platform=browser --format=iife --external:none",
    "smoke-test": "npm run build && electron . --smoke-test",
    "renderer-smoke-test": "npm run build && electron . --renderer-smoke-test",
    "start": "npm run build && electron ."
  },
  "dependencies": {
    "@types/three": "^0.184.0",
    "three": "^0.184.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/ws": "^8.18.0",
    "electron": "^41.0.0",
    "esbuild": "^0.28.0",
    "typescript": "^5.8.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
